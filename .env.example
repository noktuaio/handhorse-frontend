# HandHorse APIs (desenvolvimento local — ver handhorse/README.md)
# Next.js corre em http://localhost:3000 — não use 3000 para as APIs.

# Auth + users (access-control, serverless-offline)
NEXT_PUBLIC_HANDHORSE_API_URL=http://localhost:3001

# Cavalos e restantes rotas JWT (animals service)
NEXT_PUBLIC_HANDHORSE_ANIMALS_API_URL=http://localhost:3002

# Lançamentos financeiros (finance service)
NEXT_PUBLIC_HANDHORSE_FINANCE_API_URL=http://localhost:3003

# --- `next build` (S3 / CloudFront) ---
# No Next, .env.local ganha a .env.production. O script scripts/deploy-static-to-s3.sh copia
# .env.production → .env.production.local só durante o build (essa combinação sobrepõe .env.local).
# Para `next build` manual com APIs remotas, cria .env.production.local com as mesmas chaves HTTPS.

# --- Deploy estático (S3 + CloudFront) — variáveis para o script, não para o Next ---
# Opção rápida (variáveis fixas no script): ./deploy.sh
# Ou após terraform apply em frontend/terraform:
#   export AWS_S3_BUCKET=$(terraform output -raw s3_bucket_name)
#   export AWS_REGION=$(terraform output -raw aws_region)
#   export CLOUDFRONT_DISTRIBUTION_ID=$(terraform output -raw cloudfront_distribution_id)
