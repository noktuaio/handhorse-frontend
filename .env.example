# HandHorse APIs (desenvolvimento local — ver handhorse/README.md)
# Next.js corre em http://localhost:3000 — não use 3000 para as APIs.

# Auth + users (access-control, serverless-offline)
NEXT_PUBLIC_HANDHORSE_API_URL=http://localhost:3001

# Cavalos e restantes rotas JWT (animals service)
NEXT_PUBLIC_HANDHORSE_ANIMALS_API_URL=http://localhost:3002

# Lançamentos financeiros (finance service)
NEXT_PUBLIC_HANDHORSE_FINANCE_API_URL=http://localhost:3003
